---
import BaseLayout from '../layouts/BaseLayout.astro';

const forms = [
  { name: 'Claude.ai 网页', platform: 'claude.ai', audience: '普通用户', requirement: 'Claude 账号', note: '需网络环境 + 海外手机号' },
  { name: '桌面/移动 App', platform: 'Windows / macOS / iOS / Android', audience: '移动端用户', requirement: 'Claude 账号', note: '需账号 + 网络环境' },
  { name: 'Claude Code CLI', platform: 'macOS / Linux / Windows', audience: '开发者', requirement: 'Pro / Max / Team', note: '需订阅 + 网络环境' },
  { name: 'Claude API', platform: 'console.anthropic.com', audience: '开发者', requirement: 'API 账号 + 付费', note: '需海外支付' },
];

const verifyErrors = [
  { error: 'Unsupported phone line type', cause: 'VoIP / 虚拟号 / 座机被识别', solution: '换实体 SIM 卡或真实移动线路', severity: '高', href: '/docs/claude/errors/unsupported-phone' },
  { error: 'phone_number_temp_blocked', cause: '试错过多，号码临时锁定', solution: '等 24 小时，换号码或环境', severity: '中', href: '/docs/claude/errors/temp-blocked' },
  { error: 'Number already used too many times', cause: '号码绑定账号达上限', solution: '更换长期独占号码', severity: '高', href: '/docs/claude/errors/number-used' },
  { error: '验证码已发送但收不到', cause: '区号不在官方服务区', solution: '确认号码归属地为支持地区', severity: '高', href: '/docs/claude/errors/no-code-received' },
  { error: 'VoIP numbers are not accepted', cause: '虚拟号被拒', solution: '停用 Google Voice / TextNow', severity: '高', href: '/docs/claude/errors/voip-rejected' },
  { error: 'Error / 无响应', cause: '频繁请求被限流或服务器问题', solution: '等待 1-2 小时，切换网络重试', severity: '低', href: '/docs/claude/errors/temp-blocked' },
];

const plans = [
  { name: 'Pro', price: '$20', period: '/月', features: ['Claude.ai 全功能', 'Claude Code 基础用量', '优先访问新模型', '200K 上下文'], popular: false },
  { name: 'Max 5x', price: '$100', period: '/月', features: ['Pro 全部功能', 'Claude Code 5x 用量', '适合重度开发者', '优先支持'], popular: true },
  { name: 'Max 20x', price: '$200', period: '/月', features: ['Pro 全部功能', 'Claude Code 20x 用量', '团队级用量', '最高优先级'], popular: false },
];

const payMethods = [
  { method: '海外信用卡', difficulty: '高', success: '中', desc: 'Visa/Master 信用卡 + 稳定 IP，国内双币卡常被拒', risk: '低（官方）' },
  { method: '第三方代充', difficulty: '低', success: '高', desc: '微信/支付宝人民币支付，最常用方式', risk: '中（需选可信平台）' },
  { method: '虚拟卡', difficulty: '中', success: '中', desc: 'Privacy / Revolut 等，成功率参差不齐', risk: '中' },
  { method: 'Claude API + 第三方客户端', difficulty: '中', success: '高', desc: '按 token 计费，无需订阅', risk: '低' },
];

const installSteps = [
  { os: 'macOS / Linux / WSL', cmd: 'curl -fsSL https://claude.ai/install.sh | bash', note: '原生安装，支持自动更新' },
  { os: 'Windows PowerShell', cmd: 'irm https://claude.ai/install.ps1 | iex', note: '原生安装，支持自动更新' },
  { os: 'Homebrew (macOS)', cmd: 'brew install --cask claude-code', note: '包管理器安装' },
  { os: 'WinGet (Windows)', cmd: 'winget install Anthropic.ClaudeCode', note: '包管理器安装' },
  { os: 'npm (全平台)', cmd: 'npm install -g @anthropic-ai/claude-code', note: '禁止使用 sudo 安装' },
];
---

<BaseLayout title="Anthropic Claude 专区 - Codex & Claude 通关站">
  <section class="bg-gradient-to-br from-accent-600 to-accent-700 text-white">
    <div class="container-page py-16">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-14 h-14 rounded-xl bg-white text-accent-600 flex items-center justify-center font-bold text-2xl">A</div>
        <div>
          <h1 class="text-3xl font-bold">Anthropic Claude</h1>
          <p class="text-accent-100">Claude 对话 + Claude Code 终端 Agent</p>
        </div>
      </div>
      <p class="text-accent-50 max-w-2xl">Claude 是 Anthropic 推出的 AI 助手，Claude Code 是其终端编程 Agent。本专区解决注册、手机号验证、安装、订阅与支付问题。</p>
      <div class="flex flex-wrap gap-2 mt-6">
        <a href="#register" class="tag bg-white/15 text-white hover:bg-white/25">注册指南</a>
        <a href="#verify" class="tag bg-white/15 text-white hover:bg-white/25">手机号验证</a>
        <a href="#install" class="tag bg-white/15 text-white hover:bg-white/25">Claude Code 安装</a>
        <a href="#payment" class="tag bg-white/15 text-white hover:bg-white/25">订阅与支付</a>
      </div>
    </div>
  </section>

  <section id="forms" class="container-page py-16">
    <h2 class="section-title">四种产品形态</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-medium">形态</th>
            <th class="py-3 pr-4 font-medium">平台</th>
            <th class="py-3 pr-4 font-medium">适合人群</th>
            <th class="py-3 pr-4 font-medium">账号要求</th>
            <th class="py-3 font-medium">备注</th>
          </tr>
        </thead>
        <tbody>
          {forms.map((f) => (
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="py-3 pr-4 font-medium text-gray-900">{f.name}</td>
              <td class="py-3 pr-4 text-gray-600">{f.platform}</td>
              <td class="py-3 pr-4 text-gray-600">{f.audience}</td>
              <td class="py-3 pr-4 text-gray-600">{f.requirement}</td>
              <td class="py-3 text-gray-500">{f.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section id="register" class="bg-white border-y border-gray-100">
    <div class="container-page py-16">
      <h2 class="section-title">注册四步通关</h2>
      <p class="text-gray-500 mb-8">中国大陆用户注册 Claude 的核心流程</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="card">
          <div class="w-10 h-10 rounded-lg bg-accent-100 text-accent-600 flex items-center justify-center font-bold mb-3">1</div>
          <h3 class="font-medium text-gray-900 mb-2">纯净网络环境</h3>
          <p class="text-sm text-gray-500">使用美国/英国原生住宅 IP，避免免费共享节点。IP 国家需与后续手机号国家一致。</p>
        </div>
        <div class="card">
          <div class="w-10 h-10 rounded-lg bg-accent-100 text-accent-600 flex items-center justify-center font-bold mb-3">2</div>
          <h3 class="font-medium text-gray-900 mb-2">高权重邮箱</h3>
          <p class="text-sm text-gray-500">优先 Gmail，其次 Outlook、Protonmail。禁用国内邮箱和临时邮箱。</p>
        </div>
        <div class="card">
          <div class="w-10 h-10 rounded-lg bg-accent-100 text-accent-600 flex items-center justify-center font-bold mb-3">3</div>
          <h3 class="font-medium text-gray-900 mb-2">海外手机号</h3>
          <p class="text-sm text-gray-500">实体 SIM 卡最稳，其次长期独占云号码。禁用一次性接码和 VoIP。</p>
        </div>
        <div class="card">
          <div class="w-10 h-10 rounded-lg bg-accent-100 text-accent-600 flex items-center justify-center font-bold mb-3">4</div>
          <h3 class="font-medium text-gray-900 mb-2">环境一致性</h3>
          <p class="text-sm text-gray-500">IP 国家、手机号国家、时区、DNS、浏览器指纹保持一致，避免风控。</p>
        </div>
      </div>
      <div class="mt-6 text-center">
        <a href="/docs/claude/guides/registration" class="btn btn-outline text-accent-600 border-accent-300 hover:bg-accent-50">查看注册完整教程 →</a>
      </div>
    </div>
  </section>

  <section id="verify" class="container-page py-16">
    <h2 class="section-title">手机号验证问题库</h2>
    <p class="text-gray-500 mb-8">+86 号码不可用 · VoIP 号码被拒 · 常见错误与解决方案</p>
    <div class="space-y-3">
      {verifyErrors.map((e) => (
        <a href={e.href} class="card hover:border-accent-300 block">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
            <code class="font-mono text-sm bg-red-50 text-red-700 px-3 py-1.5 rounded flex-shrink-0">{e.error}</code>
            <span class={`tag ${e.severity === '高' ? 'tag-red' : e.severity === '中' ? 'tag-orange' : 'tag-gray'}`}>{e.severity}风险</span>
          </div>
          <div class="grid sm:grid-cols-2 gap-4 text-sm">
            <div>
              <span class="text-gray-400">原因：</span>
              <span class="text-gray-700">{e.cause}</span>
            </div>
            <div>
              <span class="text-gray-400">解决：</span>
              <span class="text-gray-700">{e.solution}</span>
            </div>
          </div>
          <div class="mt-2 pt-2 border-t border-gray-100 text-right">
            <span class="text-accent-600 text-xs font-medium">查看详情 →</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8 grid md:grid-cols-2 gap-4">
      <div class="card bg-green-50 border-green-200">
        <h3 class="font-semibold text-green-900 mb-2 flex items-center gap-2"><span>✓</span> 推荐方案</h3>
        <ul class="text-sm text-green-800 space-y-1 ml-4 list-disc">
          <li>海外实体 SIM 卡（美国/英国最稳）</li>
          <li>长期独占云号码（DuoPlus 等）</li>
          <li>使用 Google / Apple 账号关联注册，可能跳过验证</li>
          <li>无痕模式 + 干净 IP 重试</li>
        </ul>
      </div>
      <div class="card bg-red-50 border-red-200">
        <h3 class="font-semibold text-red-900 mb-2 flex items-center gap-2"><span>✗</span> 避免做法</h3>
        <ul class="text-sm text-red-800 space-y-1 ml-4 list-disc">
          <li>使用 +86 中国手机号</li>
          <li>使用 Google Voice、TextNow 等 VoIP</li>
          <li>一次性接码平台（号码被反复使用）</li>
          <li>频繁点击"发送验证码"（触发限流）</li>
          <li>多人共用同一账号或号码</li>
        </ul>
      </div>
    </div>

    <div class="mt-6 text-center">
      <a href="/docs/claude/guides/phone-verification" class="btn btn-outline text-accent-600 border-accent-300 hover:bg-accent-50">查看手机号验证完整指南 →</a>
    </div>
  </section>

  <section id="install" class="bg-white border-y border-gray-100">
    <div class="container-page py-16">
      <h2 class="section-title">Claude Code 安装</h2>
      <p class="text-gray-500 mb-4">系统要求：macOS 13+ / Windows 10 1809+ / Ubuntu 20.04+ / 4GB RAM</p>
      <p class="text-gray-500 mb-8">订阅要求：需 Claude Pro / Max / Team / Enterprise / Console 计划（免费 Claude.ai 不含 Claude Code）</p>
      <div class="space-y-3">
        {installSteps.map((s) => (
          <div class="card">
            <div class="flex flex-col sm:flex-row sm:items-center gap-3">
              <span class="tag tag-orange flex-shrink-0 w-40 justify-center">{s.os}</span>
              <code class="font-mono text-sm bg-gray-100 px-3 py-2 rounded text-gray-800 flex-1">{s.cmd}</code>
            </div>
            <p class="text-xs text-gray-500 mt-2">{s.note}</p>
          </div>
        ))}
      </div>

      <div class="mt-6 text-center">
        <a href="/docs/claude/guides/install-code" class="btn btn-outline text-accent-600 border-accent-300 hover:bg-accent-50">查看 Claude Code 安装完整教程 →</a>
      </div>
    </div>
  </section>

  <section id="payment" class="container-page py-16">
    <h2 class="section-title">订阅套餐</h2>
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      {plans.map((p) => (
        <div class={`card ${p.popular ? 'border-accent-500 border-2 relative' : ''}`}>
          {p.popular && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 tag tag-orange">推荐</span>
          )}
          <h3 class="font-semibold text-gray-900 mb-1">{p.name}</h3>
          <div class="flex items-baseline gap-1 mb-4">
            <span class="text-3xl font-bold text-gray-900">{p.price}</span>
            <span class="text-gray-500">{p.period}</span>
          </div>
          <ul class="space-y-2 text-sm text-gray-600">
            {p.features.map((f) => (
              <li class="flex items-start gap-2">
                <span class="text-accent-500 mt-0.5">✓</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <h3 class="font-semibold text-gray-900 mb-4">国内支付方式对比</h3>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-medium">方式</th>
            <th class="py-3 pr-4 font-medium">难度</th>
            <th class="py-3 pr-4 font-medium">成功率</th>
            <th class="py-3 pr-4 font-medium">说明</th>
            <th class="py-3 font-medium">风险</th>
          </tr>
        </thead>
        <tbody>
          {payMethods.map((m) => (
            <tr class="border-b border-gray-100">
              <td class="py-3 pr-4 font-medium text-gray-900">{m.method}</td>
              <td class="py-3 pr-4">
                <span class={`tag ${m.difficulty === '高' ? 'tag-red' : m.difficulty === '中' ? 'tag-orange' : 'tag-green'}`}>{m.difficulty}</span>
              </td>
              <td class="py-3 pr-4">
                <span class={`tag ${m.success === '高' ? 'tag-green' : m.success === '中' ? 'tag-orange' : 'tag-red'}`}>{m.success}</span>
              </td>
              <td class="py-3 pr-4 text-gray-600">{m.desc}</td>
              <td class="py-3 text-gray-500">{m.risk}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-8 card bg-amber-50 border-amber-200">
      <h3 class="font-semibold text-amber-900 mb-2 flex items-center gap-2"><span>⚠️</span> 防封与避坑</h3>
      <ul class="text-sm text-amber-800 space-y-1 ml-4 list-disc">
        <li>避免频繁切换 IP 地区，保持登录环境稳定</li>
        <li>不要多人共用同一 Claude 账号</li>
        <li>不要发起退款后继续使用（极易封号）</li>
        <li>不要使用异常支付渠道或盗刷信用卡</li>
        <li>不要将 API Key、验证码、完整手机号发到公开论坛</li>
      </ul>
    </div>

    <div class="mt-6 text-center">
      <a href="/docs/claude/guides/subscription-payment" class="btn btn-outline text-accent-600 border-accent-300 hover:bg-accent-50">查看订阅与支付完整指南 →</a>
    </div>
  </section>
</BaseLayout>
