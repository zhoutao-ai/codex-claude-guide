---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到 - Codex & Claude 通关站">
  <section class="container-page py-24 text-center">
    <div class="text-6xl font-bold text-gray-300 mb-4">404</div>
    <h1 class="text-2xl font-semibold text-gray-900 mb-3">页面未找到</h1>
    <p class="text-gray-500 mb-8">你访问的页面不存在或已被移动。</p>
    <div class="flex gap-3 justify-center">
      <a href="/" class="btn btn-primary">返回首页</a>
      <a href="/diagnose" class="btn btn-outline">问题诊断器</a>
    </div>
  </section>
</BaseLayout>
