---
import BaseLayout from '../layouts/BaseLayout.astro';

const stats = [
  { number: '40+', label: '常见问题' },
  { number: '2', label: '产品专区' },
  { number: '15+', label: '错误码解析' },
  { number: '4', label: '安装平台' },
];

const quickLinks = [
  { title: 'Codex CLI 安装失败', desc: 'npm 权限、PATH、装错包', tag: 'Codex', color: 'blue', href: '/codex#install' },
  { title: 'Claude 手机号验证失败', desc: 'Unsupported phone line type', tag: 'Claude', color: 'orange', href: '/claude#verify' },
  { title: 'Claude Pro 支付被拒', desc: '国内双币卡风控', tag: 'Claude', color: 'orange', href: '/claude#payment' },
  { title: 'Codex vs Claude Code', desc: '该怎么选？', tag: '对比', color: 'gray', href: '/compare' },
];

const updates = [
  { date: '06-28', text: 'Claude 4 Sonnet 已向 Pro 用户开放', status: 'new' },
  { date: '06-25', text: 'OpenAI Codex CLI 0.101 发布，支持 MCP 协议', status: 'new' },
  { date: '06-22', text: 'Claude 注册对 VoIP 号码风控加强，需复核方案', status: 'warn' },
  { date: '06-18', text: 'Codex 桌面应用上架 Microsoft Store（部分地区）', status: 'new' },
];
---

<BaseLayout>
  <section class="bg-gradient-to-b from-brand-50 to-white border-b border-gray-100">
    <div class="container-page py-20 text-center">
      <span class="tag tag-blue mb-4">中文开发者通关指南 · 2026 版</span>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4 tracking-tight">
        Codex & Claude<br class="sm:hidden" /> 所有问题，一站解决
      </h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8">
        从安装、注册、手机号验证，到访问、订阅、支付与排错。覆盖 OpenAI Codex 与 Anthropic Claude 的全流程实操指南。
      </p>
      <div class="max-w-xl mx-auto flex gap-2">
        <input
          type="text"
          placeholder="输入错误提示，如 Unsupported phone line type"
          class="flex-1 px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
        />
        <button class="btn btn-primary">搜索</button>
      </div>
      <div class="grid grid-cols-4 gap-4 max-w-2xl mx-auto mt-12">
        {stats.map((s) => (
          <div>
            <div class="text-2xl sm:text-3xl font-bold text-brand-600">{s.number}</div>
            <div class="text-xs sm:text-sm text-gray-500 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page py-16">
    <h2 class="section-title text-center">选择你的产品入口</h2>
    <p class="text-center text-gray-500 mb-10">两款顶级 AI 编程工具，各有侧重</p>
    <div class="grid md:grid-cols-2 gap-6">
      <a href="/codex" class="card group block">
        <div class="flex items-start justify-between mb-4">
          <div>
            <div class="w-12 h-12 rounded-xl bg-gray-900 text-white flex items-center justify-center font-bold text-lg mb-3">O</div>
            <h3 class="text-xl font-semibold text-gray-900">OpenAI Codex</h3>
            <p class="text-sm text-gray-500 mt-1">OpenAI 出品的 AI 编程 Agent</p>
          </div>
          <span class="text-gray-300 group-hover:text-brand-500 transition">→</span>
        </div>
        <p class="text-sm text-gray-600 mb-4">桌面应用、VS Code 插件、CLI 与 ChatGPT 内置四种形态，适合快速原型与全栈开发。</p>
        <div class="flex flex-wrap gap-2">
          <span class="tag tag-blue">快速开始</span>
          <span class="tag tag-gray">安装教程</span>
          <span class="tag tag-gray">手机号验证</span>
          <span class="tag tag-gray">API 配置</span>
        </div>
      </a>
      <a href="/claude" class="card group block">
        <div class="flex items-start justify-between mb-4">
          <div>
            <div class="w-12 h-12 rounded-xl bg-accent-600 text-white flex items-center justify-center font-bold text-lg mb-3">A</div>
            <h3 class="text-xl font-semibold text-gray-900">Anthropic Claude</h3>
            <p class="text-sm text-gray-500 mt-1">Claude 对话 + Claude Code 终端 Agent</p>
          </div>
          <span class="text-gray-300 group-hover:text-accent-500 transition">→</span>
        </div>
        <p class="text-sm text-gray-600 mb-4">Claude.ai 网页、桌面/移动 App、Claude Code CLI 与 API，擅长深度代码分析与大型重构。</p>
        <div class="flex flex-wrap gap-2">
          <span class="tag tag-orange">注册指南</span>
          <span class="tag tag-gray">Claude Code</span>
          <span class="tag tag-gray">Pro 充值</span>
          <span class="tag tag-gray">防封技巧</span>
        </div>
      </a>
    </div>
  </section>

  <section class="bg-white border-y border-gray-100">
    <div class="container-page py-16">
      <h2 class="section-title text-center">常见问题快速入口</h2>
      <p class="text-center text-gray-500 mb-10">点击直接跳转到对应解决方案</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {quickLinks.map((item) => (
          <a href={item.href} class="card group">
            <span class={`tag tag-${item.color} mb-3`}>{item.tag}</span>
            <h3 class="font-medium text-gray-900 mb-1 group-hover:text-brand-600 transition">{item.title}</h3>
            <p class="text-xs text-gray-500">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page py-16">
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <div>
        <h2 class="section-title">问题诊断器</h2>
        <p class="text-gray-600 mb-6">不知道问题出在哪？选择产品和环节，系统帮你定位原因并给出操作步骤。</p>
        <ul class="space-y-3 text-sm text-gray-600">
          <li class="flex items-start gap-2">
            <span class="text-brand-500 mt-0.5">✓</span>
            <span>覆盖安装、注册、验证、支付四大环节</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-500 mt-0.5">✓</span>
            <span>每个错误提示附带风险等级与替代方案</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-500 mt-0.5">✓</span>
            <span>支持按错误码和现象关键词搜索</span>
          </li>
        </ul>
        <a href="/diagnose" class="btn btn-primary mt-6">开始诊断 →</a>
      </div>
      <div class="card bg-gray-50">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-sm font-medium">1</div>
          <span class="text-sm text-gray-600">选择产品</span>
        </div>
        <div class="ml-4 border-l-2 border-gray-200 h-6"></div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-sm font-medium">2</div>
          <span class="text-sm text-gray-600">选择环节与具体错误</span>
        </div>
        <div class="ml-4 border-l-2 border-gray-200 h-6"></div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-sm font-medium">3</div>
          <span class="text-sm text-gray-600">查看原因、风险与推荐操作</span>
        </div>
        <div class="ml-4 border-l-2 border-gray-200 h-6"></div>
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-green-100 text-green-600 flex items-center justify-center text-sm font-medium">✓</div>
          <span class="text-sm text-gray-600 font-medium">跳转完整教程</span>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-100">
    <div class="container-page py-16">
      <h2 class="section-title">最新动态</h2>
      <div class="space-y-3">
        {updates.map((u) => (
          <div class="flex items-center justify-between py-3 border-b border-gray-100 last:border-0">
            <div class="flex items-center gap-4">
              <span class="text-xs text-gray-400 font-mono w-12">{u.date}</span>
              <span class="text-sm text-gray-700">{u.text}</span>
            </div>
            {u.status === 'warn' ? (
              <span class="tag tag-red">需复核</span>
            ) : (
              <span class="tag tag-green">新</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
