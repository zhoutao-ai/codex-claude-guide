---
import '../styles/global.css';

const navItems = [
  { href: '/', label: '首页' },
  { href: '/codex', label: 'Codex' },
  { href: '/claude', label: 'Claude' },
  { href: '/compare', label: '对比' },
  { href: '/errors', label: '错误码库' },
  { href: '/diagnose', label: '问题诊断' },
];

export interface Props {
  title: string;
  description?: string;
  product?: 'Codex' | 'Claude' | '通用';
  category?: string;
  severity?: '低' | '中' | '高';
  lastUpdated?: string;
  prev?: { href: string; title: string };
  next?: { href: string; title: string };
}

const {
  title,
  description = 'Codex & Claude 通关站 - 详细教程与问题解决方案',
  product = '通用',
  category,
  severity,
  lastUpdated = '2026-06-29',
  prev,
  next,
} = Astro.props;

const productColor = product === 'Codex' ? 'tag-blue' : product === 'Claude' ? 'tag-orange' : 'tag-gray';
const severityColor = severity === '高' ? 'tag-red' : severity === '中' ? 'tag-orange' : 'tag-green';
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} - Codex & Claude 通关站</title>
</head>
<body>
  <header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-200">
    <nav class="container-page flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 font-semibold text-gray-900">
        <span class="w-8 h-8 rounded-lg bg-brand-600 text-white flex items-center justify-center text-sm font-bold">CC</span>
        <span class="hidden sm:inline">Codex & Claude 通关站</span>
      </a>
      <div class="flex items-center gap-1 sm:gap-4 text-sm">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`px-2 sm:px-3 py-1.5 rounded-md transition hover:bg-gray-100 ${Astro.url.pathname === item.href ? 'text-brand-600 font-medium' : 'text-gray-600'}`}
          >
            {item.label}
          </a>
        ))}
      </div>
    </nav>
  </header>

  <main>
    <div class="container-page py-8 lg:py-12">
      <div class="max-w-3xl mx-auto">
        <!-- Breadcrumb -->
        <nav class="text-sm text-gray-500 mb-6 flex items-center gap-2 flex-wrap">
          <a href="/" class="hover:text-brand-600">首页</a>
          <span>/</span>
          {product === 'Codex' && <a href="/codex" class="hover:text-brand-600">Codex 专区</a>}
          {product === 'Claude' && <a href="/claude" class="hover:text-brand-600">Claude 专区</a>}
          {product === '通用' && <a href="/errors" class="hover:text-brand-600">错误码库</a>}
          <span>/</span>
          <span class="text-gray-700">{title}</span>
        </nav>

        <!-- Article header -->
        <div class="mb-8">
          <div class="flex items-center gap-2 mb-4 flex-wrap">
            <span class={`tag ${productColor}`}>{product}</span>
            {category && <span class="tag tag-gray">{category}</span>}
            {severity && <span class={`tag ${severityColor}`}>{severity}风险</span>}
            <span class="text-xs text-gray-400 ml-auto">最后更新：{lastUpdated}</span>
          </div>
          <h1 class="text-3xl font-bold text-gray-900 mb-3">{title}</h1>
          <p class="text-gray-500 text-lg">{description}</p>
        </div>

        <!-- Article content -->
        <article class="prose-article">
          <slot />
        </article>

        <!-- Prev/Next navigation -->
        {(prev || next) && (
          <div class="mt-12 pt-8 border-t border-gray-200 grid grid-cols-2 gap-4">
            {prev ? (
              <a href={prev.href} class="card group text-left">
                <div class="text-xs text-gray-400 mb-1">← 上一篇</div>
                <div class="font-medium text-gray-900 group-hover:text-brand-600 transition">{prev.title}</div>
              </a>
            ) : <div></div>}
            {next ? (
              <a href={next.href} class="card group text-right">
                <div class="text-xs text-gray-400 mb-1">下一篇 →</div>
                <div class="font-medium text-gray-900 group-hover:text-brand-600 transition">{next.title}</div>
              </a>
            ) : <div></div>}
          </div>
        )}

        <!-- Back to top -->
        <div class="mt-8 text-center">
          <a href="#" class="text-sm text-gray-400 hover:text-brand-600">↑ 返回顶部</a>
        </div>
      </div>
    </div>
  </main>

  <footer class="mt-24 border-t border-gray-200 bg-white">
    <div class="container-page py-10 grid grid-cols-1 md:grid-cols-3 gap-8 text-sm text-gray-500">
      <div>
        <div class="flex items-center gap-2 font-semibold text-gray-900 mb-3">
          <span class="w-7 h-7 rounded-lg bg-brand-600 text-white flex items-center justify-center text-xs font-bold">CC</span>
          Codex & Claude 通关站
        </div>
        <p>中文开发者的 OpenAI Codex 与 Anthropic Claude 全问题解决指南。安装、验证、访问、支付，一站通关。</p>
      </div>
      <div>
        <div class="font-medium text-gray-900 mb-3">内容导航</div>
        <ul class="space-y-2">
          <li><a href="/codex" class="hover:text-brand-600">Codex 专区</a></li>
          <li><a href="/claude" class="hover:text-brand-600">Claude 专区</a></li>
          <li><a href="/compare" class="hover:text-brand-600">对比测评</a></li>
          <li><a href="/errors" class="hover:text-brand-600">错误码库</a></li>
        </ul>
      </div>
      <div>
        <div class="font-medium text-gray-900 mb-3">工具</div>
        <ul class="space-y-2">
          <li><a href="/diagnose" class="hover:text-brand-600">问题诊断器</a></li>
          <li><a href="/quick-start" class="hover:text-brand-600">快速开始向导</a></li>
          <li><a href="/env-check" class="hover:text-brand-600">环境检测工具</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-100 py-6 text-center text-xs text-gray-400">
      <p>本站为技术信息指南，不提供翻墙工具、账号买卖或代充服务。内容仅供学习参考，使用时请遵守相关服务条款与法律法规。</p>
      <p class="mt-2">© 2026 Codex & Claude 通关站 · 最后更新 2026-06-29</p>
    </div>
  </footer>
</body>
</html>
